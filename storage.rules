rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Path: users/{uid}/card-images/{uuid}.{ext}
    // filename MUST be a RFC-4122 UUID + lowercase ext (jpg|jpeg|png|webp|pdf).
    match /users/{uid}/card-images/{imageId} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        imageId.matches('[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.(jpg|jpeg|png|webp|pdf)') &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*|application/pdf');

      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
