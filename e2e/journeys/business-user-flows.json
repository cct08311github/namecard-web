      "goal": "用相機/上傳照片建立一張名片",
      "expected_clicks": 2,
      "steps": [
        { "action": "navigate", "to": "/", "note": "從時間軸首頁出發" },
        {
          "action": "find_entry",
          "look_for": "拍照 / scan / OCR / 📷",
          "scope": "AppShell rail + 首頁 quickActions + MobileFab"
        },
        { "action": "click", "target": "拍照建檔入口" },
        { "action": "verify", "url_contains": "/cards/scan" },
        { "action": "upload", "file": "fixtures/sample-card.jpg" },
        { "action": "verify", "element": "OCR 解析結果欄位 / 校對表單" }
      ],
      "success_criteria": {
        "url": "/cards/scan",
        "clicks_used_<=": 2,
        "must_be_reachable_without_typing_url": true
      }
    },
    {
      "id": "B_voice_capture",
      "name": "語音建檔",
      "from": "/",
      "goal": "用講話建立一張新名片",
      "expected_clicks": 1,
      "steps": [
        { "action": "navigate", "to": "/" },
        { "action": "click", "target": "🎙️ 語音建卡 (quickAction or rail)" },
        { "action": "verify", "url_contains": "/cards/voice" },
        { "action": "verify", "element": "錄音按鈕 / Recorder UI" }
      ],
      "success_criteria": {
        "url": "/cards/voice",
        "clicks_used_<=": 1
      }
    },
    {
      "id": "C_manual_capture",
      "name": "手動建檔",
      "from": "/",
      "goal": "手動填表建立一張名片",
      "expected_clicks": 2,
      "steps": [
        { "action": "navigate", "to": "/" },
        { "action": "click", "target": "新增 / ＋ rail link" },
        { "action": "verify", "url_contains": "/cards/new" },
        { "action": "verify", "element": "<form> + 姓名欄位" }
      ],
      "success_criteria": {
        "url": "/cards/new",
        "clicks_used_<=": 2
      }
    },
    {
      "id": "D_find_person",
