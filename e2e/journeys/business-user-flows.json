      "goal": "講一句話讓系統自動找卡並寫入 timeline log",
      "expected_clicks": 1,
      "steps": [
        { "action": "navigate", "to": "/" },
        { "action": "click", "target": "🗣️ 對話速記 (quickAction or rail)" },
        { "action": "verify", "url_contains": "/log" },
        { "action": "verify", "element": "錄音 / 文字輸入區" }
      ],
      "success_criteria": {
        "url": "/log",
        "clicks_used_<=": 1
      }
    },
    {
      "id": "F_triage_followups",
      "name": "Triage：⏰ 該 ping 了 → ✅ 已聯絡",
      "from": "/",
      "goal": "看到首頁的 follow-up 提醒 → 進去 → 標記已聯絡 → 設下次提醒",
      "expected_clicks": 3,
      "steps": [
        { "action": "navigate", "to": "/" },
        { "action": "click", "target": "⏰ N 個人該 ping 了 / 追蹤 nav" },
        { "action": "verify", "url_contains": "/followups" },
        { "action": "click", "target": "第一張卡的「已聯絡」按鈕" },
        { "action": "click", "target": "下次提醒 / snooze 控制" },
        { "action": "verify", "element": "確認 toast 或狀態 badge 更新" }
