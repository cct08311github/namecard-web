      "/admin",
      "/cards/duplicates",
      "/cards/[id]",
      "/companies/[slug]",
      "/events/[tag]",
      "/export"
    ],
    "mobile_fab_actions": [
      "/log",
      "/cards/voice",
      "OPEN_SEARCH_EVENT",
      "/followups (only when followupsTotal>0)"
    ],
    "home_quick_actions_post_onboarding": [
      "/log",
      "/cards/voice",
      "/followups (only when followupsTotal>0)"
    ],
    "onboarding_hero_paths_zero_cards_only": [
      "/cards/voice",
      "/cards/scan",
      "/cards/new",
      "/import"
    ]
