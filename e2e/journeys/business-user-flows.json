    },
    {
      "id": "G_inline_edit",
      "name": "編輯一張卡",
      "from": "/cards",
      "goal": "開一張卡 → 改一個欄位 → 存",
      "expected_clicks": 3,
      "steps": [
        { "action": "navigate", "to": "/cards" },
        { "action": "click", "target": "任一張卡的卡面" },
        { "action": "verify", "url_matches": "/cards/[id]" },
        { "action": "click", "target": "「編輯」或 inline edit 觸發" },
        { "action": "type", "field": "備註 / 任意欄位", "text": "audit-note" },
        { "action": "verify", "element": "「儲存」按鈕 visible" }
      ],
      "success_criteria": {
        "edit_mode_reachable": true,
        "clicks_used_<=": 3
      }
    },
    {
      "id": "H_group_view",
      "name": "群組視角：公司／場合溫度分布",
      "from": "/",
      "goal": "進到一家公司 → 看溫度分布／待追蹤 → 點進該公司某張卡",
      "expected_clicks": 3,
      "steps": [
        { "action": "navigate", "to": "/" },
        { "action": "click", "target": "公司 nav (rail)" },
        { "action": "verify", "url_contains": "/companies" },
        { "action": "click", "target": "第一家公司 row" },
        { "action": "verify", "url_matches": "/companies/.*" },
        { "action": "verify", "element": "溫度分布 / 待追蹤指標 / 卡片列表" },
        { "action": "click", "target": "公司詳情頁的某張名片" },
        { "action": "verify", "url_matches": "/cards/[id]" }
      ],
      "success_criteria": {
        "drill_down_works": true,
        "clicks_used_<=": 3
      }
    }
  ]
}
