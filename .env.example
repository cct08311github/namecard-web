# ==================== Firebase Client SDK ====================
# 取得方式：Firebase Console → Project Settings → General → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ==================== Firebase Admin SDK ====================
# 取得方式：Firebase Console → Project Settings → Service accounts → Generate new private key
# 建議把 JSON 放到 ~/.config/namecard/service-account.json 並設 chmod 600
# 這裡貼絕對路徑，不要把 JSON 內容直接塞進 env
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
FIREBASE_ADMIN_PROJECT_ID=

# ==================== Auth Whitelist ====================
# 逗號分隔的允許登入 email 清單（Tailnet 成員 ≠ 應用授權）
ALLOWED_EMAILS=you@example.com,colleague1@example.com

# ==================== Session Cookies ====================
# 用來簽 session cookie 的 secret（32+ 字元隨機字串）
SESSION_COOKIE_SECRET=

# ==================== OCR Providers ====================
# 主 provider: minimax | openai
OCR_PROVIDER=minimax

# MiniMax（主力）
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# OpenAI（備援）
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4o

# ==================== Typesense ====================
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=

# ==================== Rate Limiting ====================
OCR_DAILY_LIMIT_PER_USER=50

# ==================== Monitoring / Alerts ====================
# Telegram Bot（UptimeRobot webhook 用）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==================== Next.js ====================
NEXT_TELEMETRY_DISABLED=1
